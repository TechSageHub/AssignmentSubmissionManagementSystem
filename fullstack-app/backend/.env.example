PORT=5000

# ============================================
# Database Configuration
# ============================================
# Set DB_TYPE to 'mssql' (default) for local SQL Server, or 'postgres' for Render/PostgreSQL
# DB_TYPE=mssql

# --- SQL Server (local development) ---
DB_SERVER=localhost
DB_PORT=1433
DB_DATABASE=AssignmentSystem
DB_USER=sa
DB_PASSWORD=your_password_here
DB_ENCRYPT=false

# --- PostgreSQL (Render production) ---
# Uncomment these and set DB_TYPE=postgres when deploying
# DB_HOST=localhost
# DB_PORT=5432
# DB_DATABASE=assignmentsystem
# DB_USER=postgres
# DB_PASSWORD=your_pg_password
# DB_SSL=false

JWT_SECRET=change_this_to_a_random_secret_key
UPLOAD_PATH=uploads
FRONTEND_URL=http://localhost:5173

# Email (SMTP)
EMAIL_FROM=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
